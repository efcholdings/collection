// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model Artwork {
  id          String   @id @default(uuid())
  originalId  String   @unique
  title       String
  artist      String
  year        String?
  medium      String?
  category    String?
  height      String?
  width       String?
  depth       String?
  heightCm    Float?   // Standardized numeric height for AI > < filtering
  widthCm     Float?   // Standardized numeric width for AI > < filtering
  depthCm     Float?   // Standardized numeric depth for AI > < filtering
  notes       String?
  appraisalValue String? // Placeholder for strict financial data
  purchasePrice  String? // Placeholder for strict financial data
  imagePath   String?
  imagePath2  String?
  imagePath3  String?
  imagePath4  String?
  imagePath5  String?
  description String?  // Optional detailed description
  embedding   Unsupported("vector(3072)")? // 3072-Dimensional Cartesian Space for Gemini 001
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  VIEWER
  EDITOR
  MANAGER
  ADMIN
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  hashedPassword String
  name           String?
  role           Role     @default(VIEWER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
