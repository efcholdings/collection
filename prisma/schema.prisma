// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Artwork {
  id          String   @id @default(uuid())
  originalId  String   @unique
  title       String
  artist      String
  year        String?
  medium      String?
  category    String?
  height      String?
  width       String?
  depth       String?
  notes       String?
  appraisalValue String? // Placeholder for strict financial data
  purchasePrice  String? // Placeholder for strict financial data
  imagePath   String?
  imagePath2  String?
  imagePath3  String?
  imagePath4  String?
  imagePath5  String?
  description String?  // Optional detailed description
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  VIEWER
  EDITOR
  MANAGER
  ADMIN
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  hashedPassword String
  name           String?
  role           Role     @default(VIEWER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
